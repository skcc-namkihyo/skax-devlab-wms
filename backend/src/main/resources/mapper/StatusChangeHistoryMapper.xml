<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.execnt.wms.mapper.StatusChangeHistoryMapper">

    <select id="selectStatusChangeHistoryList" parameterType="map" resultType="map">
        SELECT history_id,
               wh_cd,
               table_name,
               record_key,
               old_status,
               new_status,
               change_reason,
               change_type,
               changed_by,
               changed_at
        FROM wms.status_change_history
        ORDER BY changed_at DESC, history_id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countStatusChangeHistoryList" parameterType="map" resultType="int">
        SELECT COUNT(*)::int
        FROM wms.status_change_history
    </select>
</mapper>
